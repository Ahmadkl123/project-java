DB_USERNAME=root
DB_PASSWORD=root

# Must be base64-encoded, >= 32 bytes when decoded
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1zZWNyZXQta2V5LWZvci1qd3QtaG1hYy1zaGEyNTYtbXVzdC1iZS1sb25n

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

